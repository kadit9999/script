-- HOVER ĐỔI MÀU (GIỮ NGUYÊN KÍCH THƯỚC NÚT)
---------------------------------------------------------
local function ApplyNeonHover(btn, stroke, baseBg, hoverBg, baseText, hoverText)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = hoverBg, TextColor3 = hoverText}):Play()
        if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0, Thickness = 1.5}):Play() end
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = baseBg, TextColor3 = baseText}):Play()
        if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.7, Thickness = 1}):Play() end
    end)
end

