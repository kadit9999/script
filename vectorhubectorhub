local activeNotification = nil

local function AdvancedNotify(msg, color)
    -- Nếu đang có thông báo cũ, xóa ngay lập tức để tránh trùng lặp đè lên nhau
    if activeNotification then
        activeNotification:Destroy()
        activeNotification = nil
