    activeNotification = NotifyGui

    local Box = Instance.new("Frame", NotifyGui)
    Box.Size = UDim2.new(0, 300, 0, 40)
    Box.Position = UDim2.new(0.5, -150, 0, -60)
    Box.BackgroundColor3 = Color3.fromRGB(12, 6, 14)
    
    local BC = Instance.new("UICorner", Box) BC.CornerRadius = UDim.new(0, 6)
    local S = Instance.new("UIStroke", Box) S.Color = color S.Thickness = 1.5
    
    local Text = Instance.new("TextLabel", Box)
    Text.Size = UDim2.new(1, -20, 1, 0)
    Text.Position = UDim2.new(0, 10, 0, 0)
    Text.BackgroundTransparency = 1
    Text.Text = ">> " .. string.upper(msg)
    Text.TextColor3 = Color3.fromRGB(255, 255, 255)
    Text.Font = Enum.Font.Code
    Text.TextSize = 12
    Text.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Xuất hiện thông báo
    local tweenIn = TweenService:Create(Box, TweenInfo.new(0.3, Enum.EasingStyle.Out), {Position = UDim2.new(0.5, -150, 0, 50)})
    tweenIn:Play()
    
    -- Chờ 2.2 giây rồi tự động biến mất vĩnh viễn
    task.delay(2.2, function()
        if NotifyGui and NotifyGui.Parent then
            local tweenOut = TweenService:Create(Box, TweenInfo.new(0.3, Enum.EasingStyle.In), {Position = UDim2.new(0.5, -150, 0, -60)})
            tweenOut:Play()
            tweenOut.Completed:Connect(function()
                NotifyGui:Destroy()
                if activeNotification == NotifyGui then
                    activeNotification = nil
                end
            end)
        end
    end)
end

